{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "ask": [
      "Bash(git push:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh release create:*)",
      "Bash(aws iam:*)",
      "Bash(aws lambda create-function:*)",
      "Bash(aws lambda update-function-code:*)",
      "Bash(aws lambda update-function-configuration:*)",
      "Bash(aws lambda delete-function:*)",
      "Bash(aws lambda add-permission:*)",
      "Bash(aws lambda remove-permission:*)",
      "Bash(aws dynamodb delete-table:*)",
      "Bash(aws dynamodb delete-item:*)",
      "Bash(aws dynamodb update-table:*)",
      "Bash(aws dynamodb batch-write-item:*)",
      "Bash(aws s3 rm:*)",
      "Bash(aws s3 sync:*)",
      "Bash(aws s3 cp:*)",
      "Bash(aws cloudfront create-invalidation:*)",
      "Bash(aws cloudfront update-distribution:*)",
      "Bash(npm run setup:v2:tables:*)",
      "Bash(npm run migrate:v2:*)",
      "Bash(bash scripts/deploy-notifier.sh:*)",
      "Bash(sh scripts/deploy-notifier.sh:*)",
      "Bash(./scripts/deploy-notifier.sh:*)",
      "Bash(scripts/deploy-notifier.sh:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --mirror:*)",
      "Bash(git filter-repo:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -xfd:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Read(**/*credentials*)",
      "Read(**/.aws/**)",
      "Edit(**/frontend/config.js)",
      "Write(**/frontend/config.js)"
    ]
  }
}
